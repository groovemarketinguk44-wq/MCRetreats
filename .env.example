# ─────────────────────────────────────────────────
# MC Retreats — Environment Variables
# ─────────────────────────────────────────────────
# Copy this file to .env.local and fill in values.

# Admin Panel Password (choose something strong)
ADMIN_PASSWORD=your_secure_admin_password_here

# Admin JWT Secret (random 64-char string)
ADMIN_JWT_SECRET=replace_with_64_char_random_string_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Stripe ───────────────────────────────────────
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY_HERE
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=YOUR_STRIPE_PUBLISHABLE_KEY_HERE

# ─── Site URL ─────────────────────────────────────
# Used for Stripe redirects and canonical URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Vercel / Production Notes ────────────────────
# The content CMS writes to /data/content.json locally.
# On Vercel (read-only filesystem), edits persist to /tmp
# and are lost on redeploy. For persistent production editing:
# Option A: Use Vercel KV (free tier) — ask your developer.
# Option B: Edit content.json in code and redeploy.
